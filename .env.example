# Constantinople — Subnet 97 Configuration
# Copy this to .env and edit as needed.

# Wallet config (must exist on host at WALLET_PATH)
WALLET_NAME=validator
HOTKEY_NAME=default
WALLET_PATH=~/.bittensor/wallets

# Validator model (for hidden state verification — needs GPU)
VALIDATOR_MODEL=Qwen/Qwen2.5-7B-Instruct
TRUST_REMOTE_CODE=0

# Gateway settings
VALIDATOR_PORT=8080
EPOCH_LENGTH=300
SYNTHETIC_INTERVAL=10

# API authentication (comma-separated keys, empty = open)
API_KEYS=
MONITORING_KEYS=

# R2 audit logging (optional)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=constantinople-audit

# Docker image prefix
IMAGE_PREFIX=constantinople
